                   "certifications":certs}
            X_input,_ = preprocess_dataframe(pd.DataFrame([row]), fit_encoders=False)
            model = st.session_state.models[model_choice]

            # Prediction: compute for selected model AND for all trained models for comparison
            try:
                all_results = {}
                for name, mdl in st.session_state.models.items():
                    try:
                        if name == "MLP":
                            # Keras model returns array; take scalar prob
                            prob_val = float(np.asarray(mdl.predict(X_input)).ravel()[0])
                            pred_val = int(prob_val >= 0.5)
                        else:
                            # prefer predict_proba when available (gives proper probability)
                            if hasattr(mdl, "predict_proba"):
                                prob_val = float(mdl.predict_proba(X_input)[0][1])
                                pred_val = int(prob_val >= 0.5)
                            else:
                                # fallback to predict (may return class label or array)
                                pred_raw = mdl.predict(X_input)
                                try:
                                    pred_val = int(np.asarray(pred_raw).ravel()[0])
                                except Exception:
                                    pred_val = int(pred_raw[0])
                                # probability unknown when predict_proba not available
                                prob_val = None
                        all_results[name] = {"pred": pred_val, "prob": prob_val}
                    except Exception as inner_e:
                        all_results[name] = {"pred": "error", "prob": str(inner_e)}

                # Show chosen model prominently
                chosen = all_results.get(model_choice, None)
                if chosen is not None and chosen.get("pred") != "error":
                    ch_pred = chosen["pred"]
                    ch_prob = chosen["prob"]
                    st.write("Prediction (selected model):", "Hired ✅" if ch_pred else "Rejected ❌")
                    if ch_prob is not None:
                        st.write(f"Hiring Probability ({model_choice}): {ch_prob:.2f}")
                else:
                    st.warning(f"Selected model '{model_choice}' prediction failed")
                    if chosen:
                        st.write(chosen["prob"])

                # Show quick comparison table for all models
                try:
                    summary_rows = []
                    for nm, res in all_results.items():
                        prob_display = f"{res['prob']:.2f}" if isinstance(res["prob"], (float, np.floating)) else str(res["prob"])
                        pred_display = res["pred"]
                        summary_rows.append([nm, pred_display, prob_display])
                    df_cmp = pd.DataFrame(summary_rows, columns=["Model", "Predicted Label", "Probability"])
                    st.write("### All models — predictions")
                    st.dataframe(df_cmp)
                except Exception:
                    st.write(all_results)
            except Exception as e:
                st.warning("Prediction step failed")
                st.exception(e)

            # SHAP explanation
            try:
                X_test = st.session_state.X_test

                # use the unified Explainer API and compute explanation for the input
                explainer = shap.Explainer(model, X_test)
                sv = explainer(X_input)

                # Determine correct slicing for waterfall
                shap_for_waterfall = None
                try:
                    # multi-output models: sv.values can be a list of arrays (one per output)
                    if isinstance(sv.values, list):
                        # take first output, first sample
                        vals0 = sv.values[0]  # shape (n_samples, n_features)
                        base0 = sv.base_values[0] if isinstance(sv.base_values, (list, tuple, np.ndarray)) else sv.base_values
                        data0 = sv.data[0] if hasattr(sv, "data") and np.asarray(sv.data).ndim == 2 else sv.data
                        # build a single-sample Explanation
                        shap_for_waterfall = shap.Explanation(values=vals0[0],
                                                             base_values=(base0[0] if getattr(base0, "ndim", None) == 2 else base0),
                                                             data=(data0 if data0 is None or np.asarray(data0).ndim==1 else data0[0]),
                                                             feature_names=getattr(sv, "feature_names", None))
                    else:
                        # sv.values is an ndarray; sv[0] yields a single-sample Explanation
                        if np.asarray(sv.values).ndim == 2:
                            shap_for_waterfall = sv[0]  # Explanation for first (and only) sample
                        else:
                            shap_for_waterfall = sv
                except Exception:
                    # fallback to passing the raw sv (SHAP will error with helpful message if incompatible)
                    shap_for_waterfall = sv

                fig, ax = plt.subplots()
                shap.plots.waterfall(shap_for_waterfall, show=False)

                # add axis labels and short explanatory text (acts like a legend)
                try:
                    ax = plt.gca()
                    ax.set_xlabel("SHAP value (impact on model output)")
                    ax.set_ylabel("Feature")
                    fig.text(0.01, 0.99,
                             "Note: Positive SHAP → increases predicted probability; Negative SHAP → decreases it",
                             ha="left", va="top", fontsize=8)
                except Exception:
                    pass

                st.pyplot(fig)
            except Exception as e:
                st.warning("SHAP explanation failed")
                st.exception(e)

            # LIME explanation
            if LIME_AVAILABLE:
                try:
                    explainer = LimeTabularExplainer(
                        training_data=np.array(st.session_state.X_test),
                        feature_names=st.session_state.feature_columns,
                        class_names=["Rejected","Hired"],
                        mode="classification"
                    )
                    func = model.predict if model_choice=="MLP" else model.predict_proba
                    exp_lime = explainer.explain_instance(
                        X_input.iloc[0].values, func, num_features=5
                    )
                    st.write("### LIME Explanation")
                    st.write(exp_lime.as_list())
                except Exception as e:
                    st.warning("LIME explanation failed")
                    st.exception(e)

