def parse_list_cell(cell):
    if pd.isna(cell):
        return []
    if isinstance(cell, list):
        return cell
    text = str(cell).strip()
    try:
        val = ast.literal_eval(text)
        if isinstance(val, (list, tuple, set)):
            return [str(x).strip() for x in val]
    except Exception:
        pass
    if text.startswith("[") and text.endswith("]"):
        inner = text[1:-1]
        parts = [p.strip().strip("'").strip('"') for p in inner.split(",") if p.strip()]
        return parts
    if "," in text:
        return [p.strip() for p in text.split(",") if p.strip()]
    if text.lower() in ["", "none", "nan", "nan.0"]:
        return []
    return [text]

def compute_skill_overlap(candidate_skills, job_skills):
    if not job_skills:
        return 0.0, 0, len(candidate_skills)
    cand_set = set([s.lower() for s in candidate_skills])
    job_set = set([s.lower() for s in job_skills])
    inter = cand_set.intersection(job_set)
    return len(inter)/len(job_set), len(inter), len(cand_set)

def preprocess_dataframe(df, fit_encoders=False):
    df = df.copy()
    drop_cols = ["candidate_id", "resume_text", "job_id", "application_date"]
    df.drop(columns=[c for c in drop_cols if c in df.columns], inplace=True, errors="ignore")

    df["skills_parsed"] = df.get("skills", "").apply(parse_list_cell)
    df["job_skills_parsed"] = df.get("job_required_skills", "").apply(parse_list_cell)
    df["certs_parsed"] = df.get("certifications", "").apply(parse_list_cell)

    df["num_skills"] = df["skills_parsed"].apply(len)
    df["num_job_skills"] = df["job_skills_parsed"].apply(len)
    df["num_certs"] = df["certs_parsed"].apply(len)

    if "skill_match_score" in df.columns:
        df["skill_match_score_computed"] = pd.to_numeric(df["skill_match_score"], errors="coerce").fillna(0)
    else:
        df["skill_match_score_computed"] = [
            compute_skill_overlap(cs, js)[0] for cs, js in zip(df["skills_parsed"], df["job_skills_parsed"])
        ]
    df["skill_overlap_count"] = [
        compute_skill_overlap(cs, js)[1] for cs, js in zip(df["skills_parsed"], df["job_skills_parsed"])
    ]

    df["years_experience"] = pd.to_numeric(df.get("years_experience", 0), errors="coerce").fillna(0)
    df["age"] = pd.to_numeric(df.get("age", 25), errors="coerce").fillna(25)

    y = None
    if "label" in df.columns:
        y_raw = df["label"].astype(str).str.lower().str.strip()
        y = y_raw.map(lambda x: 1 if x in ["hired","yes","1","true","selected"] else 0)

    features = pd.DataFrame({
        "age": df["age"],
        "years_experience": df["years_experience"],
        "num_skills": df["num_skills"],
        "num_job_skills": df["num_job_skills"],
        "skill_match_score": df["skill_match_score_computed"],
        "skill_overlap_count": df["skill_overlap_count"],
        "num_certs": df["num_certs"]
    })

    cat_cols = ["gender","education_level","job_title"]
    if fit_encoders:
        st.session_state.encoders = {}
        for col in cat_cols:
            if col not in df.columns:
                df[col] = "NA"
            le = LabelEncoder()
            vals = df[col].fillna("NA").astype(str)
            le.fit(vals)
            st.session_state.encoders[col] = le
            features[col] = le.transform(vals)
        st.session_state.feature_columns = list(features.columns)
        st.session_state.scaler = StandardScaler()
        features = pd.DataFrame(
            st.session_state.scaler.fit_transform(features),
            columns=st.session_state.feature_columns, index=df.index
        )
    else:
        for col in cat_cols:
            if col not in df.columns:
                df[col] = "NA"
            le = st.session_state.encoders.get(col, None)
            vals = df[col].fillna("NA").astype(str)
            if le is None:
                le = LabelEncoder()
                le.fit(vals)
                st.session_state.encoders[col] = le
            mapped = []
            for v in vals:
                try:
                    mapped.append(int(le.transform([v])[0]))
                except Exception:
                    new_classes = list(le.classes_)+[v]
                    le.classes_ = np.array(new_classes)
                    mapped.append(int(le.transform([v])[0]))
            features[col] = mapped
        features = pd.DataFrame(
            st.session_state.scaler.transform(features),
            columns=st.session_state.feature_columns, index=df.index
        )
    return features, y

def ensure_shap_np_data(shap_exp):
	"""
	Ensure shap.Explanation.data and .values are numpy arrays with compatible 2D shapes,
	and set feature_names from session state when available.
	"""
	try:
		# convert data to numpy 2D array
		if hasattr(shap_exp, "data"):
			if isinstance(shap_exp.data, (pd.DataFrame, pd.Series)):
				shap_exp.data = shap_exp.data.values
			shap_exp.data = np.asarray(shap_exp.data)
			# force 2D for data
			if shap_exp.data.ndim == 1:
				shap_exp.data = shap_exp.data.reshape(1, -1)

		# convert values to numpy and force 2D with same n_features as data
		if hasattr(shap_exp, "values"):
			shap_exp.values = np.asarray(shap_exp.values)
			if shap_exp.values.ndim == 1:
				shap_exp.values = shap_exp.values.reshape(1, -1)
			# if values shape is (n_features,) or (n_samples,) try to align to data
			if hasattr(shap_exp, "data"):
				n_samples, n_feats = shap_exp.data.shape
				# if values have shape (n_feats,) make it (1, n_feats)
				if shap_exp.values.shape == (n_feats,):
					shap_exp.values = shap_exp.values.reshape(1, n_feats)
				# if values have shape (n_feats, 1) transpose
				if shap_exp.values.shape == (n_feats, 1):
					shap_exp.values = shap_exp.values.T
				# if values have shape (n_samples*n_classes, n_feats) or other, try to keep first n_samples
				if shap_exp.values.ndim == 2 and shap_exp.values.shape[1] == n_feats and shap_exp.values.shape[0] != n_samples:
					# prefer slicing first n_samples if reasonable
					if shap_exp.values.shape[0] > n_samples:
						shap_exp.values = shap_exp.values[:n_samples, :]
					else:
						# expand values to match samples by repeating
						shap_exp.values = np.repeat(shap_exp.values, n_samples, axis=0)[:n_samples, :]

		# base_values -> ensure array length matches samples when possible
		if hasattr(shap_exp, "base_values"):
			bv = np.asarray(shap_exp.base_values)
			if bv.ndim == 0:
				# leave scalar
				shap_exp.base_values = bv.item()
			else:
				# if scalar per feature, try to reduce to per-sample if needed
				if hasattr(shap_exp, "values") and shap_exp.values.ndim == 2:
					if bv.size == shap_exp.values.shape[1] and shap_exp.values.shape[0] == 1:
						# leave as-is (per-feature) — SHAP can accept this in some contexts
						shap_exp.base_values = bv
					elif bv.size == shap_exp.values.shape[0]:
						shap_exp.base_values = bv
					elif bv.size == 1:
						shap_exp.base_values = bv.item()
					else:
						# fallback: take first element or reshape
						shap_exp.base_values = bv.reshape(1, -1)[0] if bv.size >= 1 else bv

		# set feature names if missing
		if (not hasattr(shap_exp, "feature_names") or shap_exp.feature_names is None) and "feature_columns" in st.session_state:
			shap_exp.feature_names = st.session_state.feature_columns

	except Exception:
		# do not raise here; plotting will show a more specific error if still broken
		pass
	return shap_exp

def ensure_shap_single_sample(shap_exp):
	"""
	Ensure waterfall receives a single explanation (1D values / single-row data).
	If shap_exp contains a matrix of explanations, extract the first sample into a new Explanation.
	"""
	try:
		vals = np.asarray(getattr(shap_exp, "values", np.array([])))
		data = np.asarray(getattr(shap_exp, "data", np.array([]))) if hasattr(shap_exp, "data") else None
		# If values are 2D and have multiple rows, pick the first row
		if vals.ndim == 2 and vals.shape[0] >= 1:
			# if there is more than one sample, pick the first
			v = vals[0]
			# normalize base_values
			bv = shap_exp.base_values if hasattr(shap_exp, "base_values") else None
			try:
				bv_arr = np.asarray(bv)
				if bv_arr.ndim == 2 and bv_arr.shape[0] >= 1:
					bv = bv_arr[0]
				elif bv_arr.ndim == 1 and bv_arr.shape[0] == vals.shape[0]:
					bv = bv_arr[0]
			except Exception:
				# keep bv as-is
				pass
			d = data[0] if (data is not None and data.ndim == 2) else data
			return shap.Explanation(values=v,
									base_values=bv,
									data=d,
									feature_names=getattr(shap_exp, "feature_names", None))
	except Exception:
		# fallback: return original
		pass
	return shap_exp

