elif page=="Training":
    st.title("Train Models (All at once)")
    if "df_raw" not in st.session_state:
        st.warning("Upload dataset first")
    else:
        df = st.session_state.df_raw
        X, y = preprocess_dataframe(df, fit_encoders=True)
        X_train,X_test,y_train,y_test = train_test_split(X,y,stratify=y,test_size=0.2,random_state=42)
        ros = RandomOverSampler(random_state=42)
        X_train,y_train = ros.fit_resample(X_train,y_train)

        models = {}

        # Logistic Regression
        lr = LogisticRegression(max_iter=500)
        lr.fit(X_train,y_train)
        models["LogisticRegression"] = lr

        # MLP
        input_dim = X_train.shape[1]
        mlp = Sequential([
            Dense(64,input_dim=input_dim,activation="relu"),
            Dropout(0.2),
            Dense(32,activation="relu"),
            Dense(1,activation="sigmoid")
        ])
        mlp.compile(optimizer=Adam(0.001),loss="binary_crossentropy",metrics=["accuracy"])
        es = EarlyStopping(monitor="val_loss",patience=5,restore_best_weights=True)
        mlp.fit(X_train,y_train,validation_split=0.2,epochs=50,batch_size=32,callbacks=[es],verbose=0)
        models["MLP"] = mlp

        # XGBoost
        if XGB_AVAILABLE:
            xgb_clf = xgb.XGBClassifier(use_label_encoder=False,eval_metric="logloss")
            xgb_clf.fit(X_train,y_train)
            models["XGBoost"] = xgb_clf

        st.session_state.models = models
        st.session_state.X_test = X_test
        st.session_state.y_test = y_test
        st.success(f"Trained: {list(models.keys())}")

        # Show confusion matrices
        fig_cm = plt.figure(figsize=(5*len(models),4))
        for i,(name,model) in enumerate(models.items()):
            if name=="MLP":
                y_pred = (model.predict(X_test)>=0.5).astype(int)
            else:
                y_pred = model.predict(X_test)
            cm = confusion_matrix(y_test,y_pred)
            ax = fig_cm.add_subplot(1,len(models),i+1)
            ax.imshow(cm,cmap="Blues")
            ax.set_title(name)
            for (j,k), val in np.ndenumerate(cm):
                ax.text(k,j,str(val),ha="center",va="center",color="w")
        st.pyplot(fig_cm)

