                    X_shap_sample = X_test.iloc[idx]
                else:
                    rng = np.random.RandomState(42)
                    sample_size = min(4, X_test.shape[0])
                    idx = rng.choice(X_test.shape[0], size=sample_size, replace=False)
                    X_shap_sample = X_test[idx]
            except Exception:
                X_shap_sample = X_test if X_test is not None else None

            for name,model in models.items():
                st.write(f"### {name}")
                # use the small sample (X_shap_sample) instead of full X_test for SHAP
                if name=="MLP":
                    explainer = shap.KernelExplainer(model.predict, X_shap_sample)
                    shap_vals = explainer.shap_values(X_shap_sample)
                    shap_exp = shap.Explanation(values=shap_vals[0],
                                                base_values=explainer.expected_value,
                                                data=X_shap_sample.values if hasattr(X_shap_sample, "values") else X_shap_sample)
                elif name=="XGBoost":
                    explainer = shap.Explainer(model)
                    shap_full = explainer(X_shap_sample)
                    shap_exp = shap.Explanation(values=shap_full.values,
                                                base_values=shap_full.base_values,
                                                data=X_shap_sample.values if hasattr(X_shap_sample, "values") else X_shap_sample)
                else:
                    explainer = shap.LinearExplainer(model, X_shap_sample)
                    shap_full = explainer(X_shap_sample)
                    shap_exp = shap.Explanation(values=shap_full.values,
                                                base_values=shap_full.base_values,
                                                data=X_shap_sample.values if hasattr(X_shap_sample, "values") else X_shap_sample)

                shap_exp = ensure_shap_np_data(shap_exp)

                fig_summary = plt.figure()
                shap.summary_plot(shap_exp.values, shap_exp.data, show=False)
                # add axis labels and explanatory text for summary (dot) plot
                try:
                    ax = plt.gca()
                    ax.set_xlabel("SHAP value (impact on model output)")
                    ax.set_ylabel("Features")
                    fig_summary.text(0.01, 0.99,
                                     "Note: Each dot shows impact of a feature value on the output.\nX = SHAP value; Y = feature",
                                     ha="left", va="top", fontsize=8)
                except Exception:
                    pass
                st.pyplot(fig_summary)
                fig_bar = plt.figure()
                shap.summary_plot(shap_exp.values, shap_exp.data, plot_type="bar", show=False)
                # add axis labels and explanatory text for bar plot
                try:
                    ax = plt.gca()
                    ax.set_xlabel("Mean |SHAP value| (feature importance)")
                    ax.set_ylabel("Features")
                    fig_bar.text(0.01, 0.99, "Note: Higher mean |SHAP value| → more important feature",
                                 ha="left", va="top", fontsize=8)
                except Exception:
                    pass
                st.pyplot(fig_bar)
        except Exception as e:
            st.warning("Global SHAP failed")
            st.exception(e)
